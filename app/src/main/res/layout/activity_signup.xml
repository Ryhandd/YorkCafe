<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".SignUpActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Outer Black Frame Container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_graphic_frame"
                android:layout_width="280dp"
                android:layout_height="220dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#2C2C2C"
                app:cardCornerRadius="0dp"
                app:strokeColor="@color/black"
                app:strokeWidth="3dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JOIN THE VIBE"
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:fontFamily="@font/anton"
                        android:letterSpacing="0.05"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Tilted Star Sticker -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_star_sticker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFEE58"
                app:cardCornerRadius="0dp"
                app:strokeColor="@color/black"
                app:strokeWidth="2.5dp"
                app:cardElevation="12dp"
                app:layout_constraintBottom_toBottomOf="@+id/card_graphic_frame"
                app:layout_constraintStart_toStartOf="@+id/card_graphic_frame"
                android:layout_marginStart="-12dp"
                android:layout_marginBottom="-12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JOIN!"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:fontFamily="@font/anton"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Input Fields Layout -->
            <LinearLayout
                android:id="@+id/layout_inputs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="36dp"
                app:layout_constraintTop_toBottomOf="@+id/card_graphic_frame">

                <!-- Name Input -->
                <EditText
                    android:id="@+id/input_name"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_black_sticker"
                    android:backgroundTint="@color/black"
                    android:hint="FULL NAME"
                    android:textColorHint="#888888"
                    android:textColor="@color/white"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textSize="15sp"
                    android:fontFamily="@font/anton"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="16dp" />

                <!-- Email Input -->
                <EditText
                    android:id="@+id/input_email"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_black_sticker"
                    android:backgroundTint="@color/black"
                    android:hint="EMAIL ADDRESS"
                    android:textColorHint="#888888"
                    android:textColor="@color/white"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textSize="15sp"
                    android:fontFamily="@font/anton"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="16dp" />

                <!-- Password Input -->
                <EditText
                    android:id="@+id/input_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_black_sticker"
                    android:backgroundTint="@color/black"
                    android:hint="PASSWORD"
                    android:textColorHint="#888888"
                    android:textColor="@color/white"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:textSize="15sp"
                    android:fontFamily="@font/anton"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="24dp" />

                <!-- Register Button (Neo-brutalism Style) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp">

                    <!-- Button Shadow -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginStart="4dp"
                        android:background="@color/black" />

                    <!-- Button Fore -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_signup_enter"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="SIGN UP"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:fontFamily="@font/anton"
                        android:letterSpacing="0.05"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@color/white"
                        app:strokeColor="@color/black"
                        app:strokeWidth="3dp"
                        app:cornerRadius="0dp" />

                </FrameLayout>

            </LinearLayout>

            <!-- Link to Log In -->
            <TextView
                android:id="@+id/txt_go_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? Log In"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layout_inputs" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
